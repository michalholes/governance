{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"noImplicitAny": true,
		"strict": false,
		"target": "ES2022",
		"lib": ["ES2022", "DOM"],
		"skipLibCheck": true
	},
	"include": ["src/governance/**/*.js", "tests/**/*.js", "types/**/*.d.ts"],
	"exclude": ["node_modules", "patches", "**/patches/**"]
}
